# =============================================
#  .env.example — Copy this file to .env
#  and fill in your own values.
#  NEVER commit the real .env to Git!
# =============================================

# Flask secret key (change this to a random string)
SECRET_KEY=your-secret-key-here

# Flask debug mode: set to True during development, False in production
FLASK_DEBUG=True

# Flask port
FLASK_PORT=5000
